#!/bin/sh
# pre-push hook: run the same tests CI runs, fail fast before pushing.
# Skip with: git push --no-verify

echo "Running CI-equivalent test suite..."

# Run the same pytest invocation as CI
python -m pytest -m "not slow" --tb=line -q --timeout=120 -p no:qt \
    --ignore=tests/test_settings_history.py \
    2>&1 | tail -5

exit_code=${PIPESTATUS[0]}

# PyQt6 teardown may return non-zero even when all tests pass.
# Check the output for actual failures instead.
if [ $exit_code -ne 0 ]; then
    # Re-run quietly to get the summary line
    result=$(python -m pytest -m "not slow" --tb=no -q --timeout=120 -p no:qt \
        --ignore=tests/test_settings_history.py 2>&1 | tail -3)

    if echo "$result" | grep -q "failed"; then
        echo ""
        echo "BLOCKED: Test failures detected. Fix before pushing."
        echo "  $result"
        exit 1
    fi

    # No "failed" in output — teardown-only crash, allow push
    echo "Tests passed (ignoring PyQt6 teardown exit code)"
fi

echo "OK: All tests pass"
exit 0
